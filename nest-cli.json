{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "stellar-service": {
      "type": "application",
      "root": "apps/stellar-service",
      "entryFile": "main",
      "sourceRoot": "apps/stellar-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/stellar-service/tsconfig.app.json"
      }
    }
  }
}
